# ==============================================================
# Meridian — Corporate Lead Generation Platform
# Copy this file to .env and fill in the values for your environment.
# ==============================================================

# --- Database (docker-compose.yml provisions a local Postgres) ---
DATABASE_URL="postgresql://meridian:meridian_dev_password@localhost:5432/meridian?schema=public"

# --- NextAuth ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- OAuth providers ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Transactional email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Meridian <notifications@meridian.io>"

# --- Media storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# Create an unsigned upload preset in your Cloudinary dashboard for the admin media library
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
